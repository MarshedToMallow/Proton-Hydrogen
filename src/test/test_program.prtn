 /*
Test 1 of ?

Fibonacci Test
    A function is defined that returns the nth Fibonacci number recursively where 0 and 1 return 1
    The function is then called on 0 to 9
*/

print("[Test 1/?] Fibonacci")

call fibonacci(n: int[0,+inf]) -> int:
    if n <= 1:
        return 1
    
    return fibonacci(n - 1) + fibonacci(n - 2)

for i in 10:
    print(i, fibonacci(i))



/*
Test 2 of ?

Factorial Test
    A function is defined that returns the Factorial of n recursively where 0 and 1 return 1
    The function is then called on 0 to 9
*/

print("[Test 2/?] Factorial")

call factorial(n: int[0,+inf]) -> int:
    if n <= 1:
        return 1
    
    return n * factorial(n - 1)

for i in 10:
    print(i, factorial(i))



/*
Test 3 of ?

Quadratic Equation Solver Test
    A function is defined that returns the value of x given a, b, and c for the equation ax^2 + bx + c = 0
    The function is then called on a few known equations
*/

print("[Test 3/?] Quadratic Equation Solver")

call solve_quadratic(a: real, b: real, c: real) -> vec[real]:
    discriminant: real = b^2 - 4*a*c

    // No real solutions
    if discriminant < 0:
        return []
    
    // 1 real solution (repeated)
    elif discriminant == 0:
        return [-b / (2*a)]
    
    // 2 real solutions
    root: real = sqrt(discriminant)
    return [(-b - root) / (2*a), (-b + root) / (2*a)]

for a, b, c in [[0.5, -4, 3], [-1, 5.(857142), -1], [5.5, 2, -3.(3)]]:
    solutions = solve_quadratic(a, b, c)
    print("Finding solution for:")
    print(a)
    print(b)
    print(c)
    
    match solutions.length case 0:
        //print(f"There are no solutions for {a}x^2 + {b}x + {c} = 0")
        print("No Solutions")
    case 1:
        //print(f"{a}x^2 + {b}x + {c} = 0 if and only if x = {solutions[0]}")
        print(solutions[0])
    else:
        //print(f"{a}x^2 + {b}x + {c} = 0 if and only if x = {solutions[0]} or {solutions[1]}")
        print(solutions[0])
        print(solutions[1])



/*
Test 4 of ?

Primes Test
    A generator function is defined that yields prime numbers in order
    Another function is defined which returns whether a number is prime
    These functions result in a circular reference
    If followed, the circular reference only goes a finite depth before reaching a base case
    The generator function is used to print every prime under 1000
*/

print("[Test 4/?] Primes")

call primes() -> yield[int]:
    yield 2
    n = 3
    while true:
        if is_prime(n):
            yield n
        n += 2

call is_prime(n: int[2,+inf]) -> bool:
    for p in primes():
        if p * p > n:
            return true
        if n % p == 0:
            return false

prime_gen: yield[int] = primes()
while true:
    p = prime_gen.next()
    if p > 1000:
        break
    print(p)



/*
Test 5 of ?

Collatz Test
    A function is defined which returns the path following the rules of the Collatz Conjecture
    The function is called on 0 to 99
*/

print("[Test 5/?] Collatz")

call get_collatz_path(n: int[1,+inf]) -> vec[int]:
    if n == 1:
        return [n]
    elif n % 2 == 0:
        return [n] + get_collatz_path(n / 2)
    else:
        return [n] + get_collatz_path(3 * n + 1)

for i in 1..99:
    path: vec[int] = get_collatz_path(i)
    //print(f"{i} -> {path}")
    print(path)



/*
Test 6 of ?

Fizz Buzz Test
    A for loop runs from 1 to 100
    If the number is divisible by 15, it prints "Fizzbuzz"
    Otherwise, if the number is divisible by 3, it prints "Fizz"
    Otherwise, if the number is divisible by 5, it prints "Buzz"
    Otherwise, it prints the number itself
*/

print("[Test 6/?] Fizz Buzz")

for i in 1..100:
    if i % 15 == 0:
        print("Fizzbuzz")
    elif i % 3 == 0:
        print("Fizz")
    elif i % 5 == 0:
        print("Buzz")
    else:
        print(i)